JWT_SECRET="supersecretkey" # This is the secret key used for signing JWT tokens. Change this to a strong, unique value in production.
JWT_COOKIE_SECURE="1" # Set to 1 to ensure cookies are only sent over HTTPS. Change to 0 if you are developing locally without HTTPS.
JWT_EXPIRES_MIN="10080" # This is the expiration time for JWT tokens in minutes. 10080 minutes equals 7 days.
DB_PATH="/path.db" # This is the path to the SQLite database file. Change this to your desired location. Make sure the directory exists and is writable by the application.